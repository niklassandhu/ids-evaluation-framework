# IDS Evaluation Framework - Environment Configuration
# Copy this file to .env and adjust the paths according to your setup.

# Path to the directory containing your datasets
DATA_DIR=./data

# Output directories (separate paths for different output types)
REPORTS_DIR=./out/reports
PROCESSED_DATA_DIR=./out/processed_datasets
MODELS_DIR=./out/saved_models

# Path to the run configuration files
CONFIG_DIR=./run_config

# Plugin directories
# These directories contain your IDS models, metrics, and attack implementations.
# You can use the provided example plugins from the repository as a starting point.
PLUGIN_IDS_DIR=./plugin_ids
PLUGIN_STATIC_METRIC_DIR=./plugin_static_metric
PLUGIN_RUNTIME_METRIC_DIR=./plugin_runtime_metric
PLUGIN_ADVERSARIAL_DIR=./plugin_adversarial
